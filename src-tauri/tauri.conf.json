{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prompt Notetaker",
  "version": "0.1.0",
  "identifier": "com.promptnotetaker.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prompt Notetaker",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Lokale prompt-manager met versiebeheer",
    "longDescription": "Prompt Notetaker — een privacy-first, offline desktop-app voor het beheren, versioneren en testen van AI-prompts.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
